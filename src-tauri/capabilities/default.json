{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:webview:deny-internal-toggle-devtools",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "*" },
        { "path": "$HOME/**" },
        { "path": "$APPDATA/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOWNLOAD/**" }
      ]
    }
  ]
}
